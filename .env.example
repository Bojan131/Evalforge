# EvalForge — required env vars
# Copy to web/.env.local and fill in real values.

# === Judge model (used by DeepEval to score outputs) ===
# IMPORTANT: pick a different family than the customer's AI to avoid same-model
# positivity bias. If customer runs OpenAI, use Anthropic. If customer runs
# Anthropic, use OpenAI.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
JUDGE_MODEL=gpt-4o
JUDGE_PROVIDER=openai

# === Embeddings (for failure clustering, week 2+) ===
EMBEDDING_MODEL=text-embedding-3-large

# === DeepEval Python sidecar URL ===
DEEPEVAL_URL=http://localhost:8787

# === DSPy Python sidecar URL (week 3+) ===
DSPY_URL=http://localhost:8788

# === Per-run cost cap (USD) ===
# Hard cap on what one optimization run can spend on judge + optimizer calls.
DEFAULT_COST_CAP_USD=5
